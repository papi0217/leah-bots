# LEAH BOTS PLATFORM - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your credentials

# ============================================================================
# TELEGRAM BOT TOKENS (REQUIRED)
# ============================================================================

# Demo Bot Token - Get from https://t.me/botfather
DEMO_BOT_TOKEN=PASTE_YOUR_DEMO_BOT_TOKEN_HERE

# Onboarding Bot Token - Get from https://t.me/botfather
ONBOARDING_BOT_TOKEN=PASTE_YOUR_ONBOARDING_BOT_TOKEN_HERE

# ============================================================================
# GROQ API CREDENTIALS (REQUIRED)
# ============================================================================

# Groq API Key - Get from https://console.groq.com
GROQ_API_KEY=PASTE_YOUR_GROQ_API_KEY_HERE

# ============================================================================
# OWNER CREDENTIALS (REQUIRED)
# ============================================================================

# Your Telegram ID - Get from https://t.me/userinfobot
OWNER_TELEGRAM_ID=PASTE_YOUR_TELEGRAM_ID_HERE

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Environment (local, staging, production)
ENVIRONMENT=production
