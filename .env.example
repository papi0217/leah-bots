# LEAH Bots Environment Configuration
# Copy this file to .env and fill in your actual values

# Telegram Bot Tokens
# Get from @BotFather on Telegram
DEMO_BOT_TOKEN=your_demo_bot_token_here
ONBOARDING_BOT_TOKEN=your_onboarding_bot_token_here

# Groq API Key
# Get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenWeather API Key
# Get from https://openweathermap.org/api
WEATHER_API_KEY=your_weather_api_key_here

# Your Telegram ID
# Get from @userinfobot on Telegram
OWNER_TELEGRAM_ID=your_telegram_id_here

# Deployment Configuration
RENDER=true
LOG_LEVEL=INFO

# Database (optional, defaults to leah_bots.db)
# DATABASE_PATH=leah_bots.db

# Rate Limiting (optional)
# RATE_LIMIT_REQUESTS=30
# RATE_LIMIT_WINDOW=60

# Timeout (optional, in seconds)
# REQUEST_TIMEOUT=30
